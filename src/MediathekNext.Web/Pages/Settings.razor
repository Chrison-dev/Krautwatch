@page "/settings"
@using MediathekNext.Web.ApiClient
@inject MediathekApiClient Api
@layout MediathekNext.Web.Layout.MainLayout
@rendermode InteractiveServer

<PageTitle>Settings — MediathekNext</PageTitle>

<div class="page-header">
  <h1 class="page-title">Settings</h1>
  <p class="page-subtitle">Configure download behaviour and catalog refresh</p>
</div>

@if (_loading)
{
  <div class="loading-state"><div class="spinner"></div>LOADING…</div>
}
else
{
  <div class="settings-group">

    <div class="field">
      <label class="field-label" for="downloadDir">Download Directory</label>
      <input class="field-input" id="downloadDir" type="text"
             @bind="_downloadDirectory" placeholder="/downloads" />
      <span class="field-hint">
        Absolute path on the host where downloaded files will be saved.
        Ensure the directory exists and is writable by the worker container.
      </span>
    </div>

    <div class="field">
      <label class="field-label" for="maxConcurrent">Max Concurrent Downloads</label>
      <input class="field-input" id="maxConcurrent" type="number" min="1" max="16"
             @bind="_maxConcurrent" />
      <span class="field-hint">
        Number of simultaneous downloads. Each spawns one ffmpeg process.
        Recommended: 1–3. Changes take effect for new jobs only.
      </span>
    </div>

    <div class="field">
      <label class="field-label" for="refreshInterval">Catalog Refresh Interval (hours)</label>
      <input class="field-input" id="refreshInterval" type="number" min="1" max="168"
             @bind="_refreshIntervalHours" />
      <span class="field-hint">
        How often the MediathekView filmliste is re-downloaded (~90 MB compressed).
        The filmliste itself is updated every ~30 min — values below 2h rarely help.
      </span>
    </div>

    @if (!string.IsNullOrEmpty(_error))
    {
      <div style="font-size:0.75rem;color:var(--accent);padding:0.5rem 0.75rem;border:1px solid var(--accent-dim);border-radius:2px">
        @_error
      </div>
    }

    <div style="padding-top:0.25rem;display:flex;gap:0.75rem;align-items:center">
      <button class="btn btn-primary" @onclick="Save" disabled="@_saving">
        @if (_saving) { <span>Saving...</span> } else { <span>Save settings</span> }
      </button>
      @if (_saved)
      {
        <span style="font-size:0.75rem;color:var(--green)">Saved</span>
      }
    </div>

    <div class="rule"></div>

    <div>
      <p class="field-label" style="margin-bottom:0.5rem">Catalog</p>
      <p class="field-hint" style="margin-bottom:0.375rem">
        Provider: <strong style="color:var(--text-2)">@_providerKey</strong>
      </p>
      <p class="field-hint" style="margin-bottom:1rem">
        The catalog refreshes automatically on the configured interval.
        A manual refresh downloads and parses the full filmliste (~90 MB)
        and takes roughly a minute on a good connection.
      </p>
      <p class="field-hint" style="color:var(--text-3)">
        Manual refresh trigger: restart core-worker to force an immediate refresh.
      </p>
    </div>

  </div>
}

@code {
  bool _loading = true;
  bool _saving = false;
  bool _saved = false;
  string _error = "";

  string _downloadDirectory = "/downloads";
  int _maxConcurrent = 2;
  int _refreshIntervalHours = 6;
  string _providerKey = "mediathekview";

  protected override async Task OnInitializedAsync()
  {
    try
    {
      var s = await Api.GetSettingsAsync();
      if (s is not null)
      {
        _downloadDirectory    = s.DownloadDirectory;
        _maxConcurrent        = s.MaxConcurrentDownloads;
        _refreshIntervalHours = s.CatalogRefreshIntervalHours;
        _providerKey          = s.CatalogProviderKey;
      }
    }
    catch { /* show defaults on API error */ }
    finally { _loading = false; }
  }

  async Task Save()
  {
    _saving = true; _saved = false; _error = "";
    try
    {
      var result = await Api.SaveSettingsAsync(new SaveSettingsRequest(
        _downloadDirectory, _maxConcurrent, _refreshIntervalHours));

      if (result is not null)
      {
        _saved = true;
        await Task.Delay(3000);
        _saved = false;
      }
      else { _error = "Save failed — check the API is reachable."; }
    }
    catch (Exception ex) { _error = ex.Message; }
    finally { _saving = false; }
  }
}
